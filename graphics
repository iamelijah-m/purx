  hline(ctx, 60, 1060, w-120);
  // stats
  const stats = [['8','AI Tools'],['10','Free Gens'],['8s','Per Caption'],['$0','To Start']];
  const sw = (w-120)/4;
  stats.forEach((s,i) => {
    const sx = 60 + sw*i + sw/2;
