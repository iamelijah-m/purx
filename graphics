    ctx.fillStyle = i%2===1 ? PURPLE2 : WHITE;
    ctx.textAlign = 'center';
    ctx.fillText(s[0], sx, 1130);
    ctx.font = '400 18px JetBrains Mono';
    ctx.fillStyle = '#444';
    ctx.fillText(s[1].toUpperCase(), sx, 1155);
  });
  ctx.font = '400 22px JetBrains Mono';
  ctx.fillStyle = '#555';
  ctx.textAlign = 'center';
  ctx.fillText('link in bio → ', w/2 - 60, 1040);
  ctx.fillStyle = PURPLE2;
  ctx.fillText('purx.live', w/2+80, 1040);
}

// ── STORY ──
function drawStory(ctx, w, h) {
  slideBase(ctx,w,h);
  drawGlow(ctx, w/2, -80, 480, 'rgba(124,58,237,0.18)');
  drawGlow(ctx, w+60, h-100, 320, 'rgba(124,58,237,0.1)');
  logo(ctx, 48, 110, 44);
  drawTag(ctx, w-400, 110, 'CREATOR INTELLIGENCE', 18);
  // progress bars
  const bars = [1, 0.6, 0];
  bars.forEach((v,i) => {
    const bx = 48 + i*(w-96)/3 + (i>0?8:0);
    const bw = (w-96)/3 - 8;
    ctx.fillStyle = '#222'; ctx.fillRect(bx,150,bw,4);
    ctx.fillStyle = PURPLE; ctx.fillRect(bx,150,bw*v,4);
  });
  ctx.font = '400 22px JetBrains Mono';
  ctx.fillStyle = '#555'; ctx.textAlign = 'left';
  ctx.fillText('STOP GUESSING. START GROWING.', 48, 280);
  ctx.font = '900 148px Barlow Condensed';
  ctx.fillStyle = WHITE; ctx.textAlign = 'left';
  ctx.fillText('AI BUILT', 48, 420);
  ctx.fillText('FOR', 48, 550);
  ctx.fillStyle = PURPLE2;
  ctx.fillText('CREATORS', 48, 680);
  ctx.fillStyle = WHITE;
  ctx.fillText('LIKE YOU.', 48, 810);
  hline(ctx, 48, 860, w-96, PURPLE);
  ctx.font = '400 30px DM Sans';
  ctx.fillStyle = '#777'; ctx.textAlign = 'left';
  const bodyText = '8 tools that write your captions, hooks,\nhashtags, and plan your whole week — in seconds.';
  bodyText.split('\n').forEach((line,i) => ctx.fillText(line, 48, 920+i*44));
  const feats = ['Caption Generator','Hook Generator','Hashtag Strategy','Content Calendar + 4 more'];
  feats.forEach((f,i) => {
    ctx.fillStyle = PURPLE; ctx.beginPath(); ctx.arc(58,1050+i*62,8,0,Math.PI*2); ctx.fill();
    ctx.font = '400 24px JetBrains Mono'; ctx.fillStyle = '#666'; ctx.textAlign='left';
    ctx.fillText(f, 82, 1057+i*62);
  });
  // CTA box
  ctx.fillStyle = 'rgba(124,58,237,0.08)';
  ctx.strokeStyle = 'rgba(124,58,237,0.25)'; ctx.lineWidth = 2;
  roundRect(ctx, 48, 1310, w-96, 120, 4); ctx.fill(); ctx.stroke();
  ctx.font = '400 18px JetBrains Mono'; ctx.fillStyle = PURPLE2; ctx.textAlign='left';
  ctx.fillText('10 FREE · NO CARD NEEDED', 72, 1360);
  ctx.font = '900 56px Barlow Condensed'; ctx.fillStyle = WHITE;
  ctx.fillText('purx.live', 72, 1410);
  ctx.font = '900 72px Barlow Condensed'; ctx.fillStyle = PURPLE2; ctx.textAlign='right';
  ctx.fillText('→', w-60, 1410);
  ctx.font = '400 18px JetBrains Mono'; ctx.fillStyle = '#444'; ctx.textAlign='left';
  ctx.fillText('↑ SWIPE UP', 48, h-48);
}

