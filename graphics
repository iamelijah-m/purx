  ctx.fillStyle = '#444';
  ctx.textAlign = 'center';
  ctx.fillText('what if captions took 8 seconds', w/2, 280);
  ctx.font = '900 180px Barlow Condensed';
  ctx.fillStyle = WHITE;
  ctx.textAlign = 'center';
  ctx.fillText('STOP', w/2, 450);
  ctx.fillText('WRITING.', w/2, 610);
