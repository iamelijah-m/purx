<script>
const BG = '#060606';
const PURPLE = '#7c3aed';
const PURPLE2 = '#9d5cf6';
const PURPLE3 = '#c4b5fd';
const WHITE = '#ffffff';
const T1 = '#f0f0f0';
const T2 = '#a0a0a0';
const T3 = '#555555';
const BORDER = '#1a1a1a';
const GREEN = '#10b981';
const RED = '#ef4444';

function rnd(cv, w, h) {
  cv.width = w; cv.height = h;
  const ctx = cv.getContext('2d');
  ctx.clearRect(0,0,w,h);
  return ctx;
}

function drawGrid(ctx, w, h, size=54) {
  ctx.strokeStyle = 'rgba(255,255,255,0.025)';
  ctx.lineWidth = 1;
  for(let x=0;x<w;x+=size){ctx.beginPath();ctx.moveTo(x,0);ctx.lineTo(x,h);ctx.stroke()}
  for(let y=0;y<h;y+=size){ctx.beginPath();ctx.moveTo(0,y);ctx.lineTo(w,y);ctx.stroke()}
}

function drawGlow(ctx, x, y, r, color) {
  const g = ctx.createRadialGradient(x,y,0,x,y,r);
  g.addColorStop(0, color);
  g.addColorStop(1, 'transparent');
  ctx.fillStyle = g;
  ctx.beginPath();
  ctx.arc(x,y,r,0,Math.PI*2);
  ctx.fill();
}

function drawTag(ctx, x, y, text, fs=22) {
  ctx.font = `500 ${fs}px 'JetBrains Mono'`;
  ctx.fillStyle = PURPLE2;
  const tw = ctx.measureText(text).width;
  const pad = 20; const h2 = fs+16;
  ctx.strokeStyle = 'rgba(124,58,237,0.3)';
  ctx.lineWidth = 1;
  ctx.fillStyle = 'rgba(124,58,237,0.1)';
  roundRect(ctx, x, y-h2+4, tw+pad*2, h2, h2/2);
  ctx.fill(); ctx.stroke();
  ctx.fillStyle = PURPLE2;
  ctx.textAlign = 'left';
  ctx.fillText(text, x+pad, y);
}

function roundRect(ctx, x, y, w, h, r) {
  ctx.beginPath();
  ctx.moveTo(x+r,y);
  ctx.lineTo(x+w-r,y);
  ctx.arcTo(x+w,y,x+w,y+r,r);
  ctx.lineTo(x+w,y+h-r);
  ctx.arcTo(x+w,y+h,x+w-r,y+h,r);
  ctx.lineTo(x+r,y+h);
  ctx.arcTo(x,y+h,x,y+h-r,r);
  ctx.lineTo(x,y+r);
  ctx.arcTo(x,y,x+r,y,r);
  ctx.closePath();
}

function logo(ctx, x, y, size=42) {
  ctx.font = `900 ${size}px 'Barlow Condensed'`;
  ctx.fillStyle = WHITE;
  ctx.textAlign = 'left';
  ctx.letterSpacing = '4px';
  ctx.fillText('PURX', x, y);
  ctx.letterSpacing = '0px';
}

function arrow(ctx, x, y, fs=28) {
  ctx.font = `700 ${fs}px 'Barlow Condensed'`;
  ctx.fillStyle = PURPLE2;
  ctx.textAlign = 'right';
  ctx.fillText('swipe →', x, y);
}

function hline(ctx, x, y, w, col=PURPLE) {
  const g = ctx.createLinearGradient(x,y,x+w,y);
  g.addColorStop(0,'transparent');
  g.addColorStop(0.5,col);
  g.addColorStop(1,'transparent');
  ctx.strokeStyle = g;
  ctx.lineWidth = 2;
  ctx.beginPath();
  ctx.moveTo(x,y);
  ctx.lineTo(x+w,y);
  ctx.stroke();
}

function pill(ctx, x, y, text, fs=20) {
  ctx.font = `500 ${fs}px 'JetBrains Mono'`;
  const tw = ctx.measureText(text).width;
  const ph = fs+20; const pw = tw+40;
  ctx.fillStyle = '#111';
  ctx.strokeStyle = '#222';
  ctx.lineWidth = 1;
  roundRect(ctx, x, y, pw, ph, 4);
  ctx.fill(); ctx.stroke();
  ctx.fillStyle = PURPLE2;
  ctx.beginPath(); ctx.arc(x+20, y+ph/2, 8, 0, Math.PI*2); ctx.fill();
  ctx.fillStyle = '#666';
  ctx.textAlign = 'left';
  ctx.fillText(text, x+38, y+ph/2+7);
  return ph+14;
}

function slideBase(ctx, w, h) {
  ctx.fillStyle = BG;
  ctx.fillRect(0,0,w,h);
  drawGrid(ctx,w,h);
}

function slideTopBottom(ctx, w, h, slideNum, total) {
  ctx.font = '400 22px JetBrains Mono';
  ctx.fillStyle = '#333';
  ctx.textAlign = 'left';
  ctx.fillText(`0${slideNum} / 0${total}`, 48, 72);
  drawTag(ctx, w-260, 72, 'PURX', 20);
  logo(ctx, 48, h-48);
}

